{
  "name": "alphonso",
  "version": "2.0.0",
  "description": "Alphonso - Local-first AI companion with 9-agent governance",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src/ --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src/ --ext .js,.jsx,.ts,.tsx --fix",
    "verify:app": "npm run test && npm run lint && npm run build",
    "verify:desktop": "npm run test && cargo test --manifest-path src-tauri/Cargo.toml",
    "updater:keygen": "tauri-signer -g",
    "updater:setup": "node scripts/updater-setup.mjs",
    "updater:verify": "node scripts/updater-verify.mjs",
    "release:updater": "npm run build && tauri build",
    "verify:ollama": "node scripts/verify-ollama.mjs",
    "proof:native-selfdev": "node scripts/proof-native-selfdev.mjs",
    "proof:rc0": "node scripts/proof-rc0.mjs",
    "auth:youtube": "node scripts/auth-youtube.mjs",
    "auth:meta": "node scripts/auth-meta.mjs",
    "auth:outlook": "node scripts/auth-outlook.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.4.47",
    "rolldown": "^0.1.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.3"
  },
  "engines": {
    "node": ">=18.0.0 <22.0.0"
  }
}