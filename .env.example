# Alphonso local runtime
OLLAMA_ORIGINS=*
OLLAMA_ENDPOINT=http://localhost:11434
ALPHONSO_BRIDGE_URL=http://localhost:4000
ALPHONSO_BRIDGE_TOKEN=
ALPHONSO_BRIDGE_PATH_PREFIX=/api/alphonso-bridge
ALPHONSO_BRIDGE_TIMEOUT_MS=15000

# Telegram bridge foundation
# Keep real values in .env only. Do not commit tokens.
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_ALLOWED_CHAT_IDS=123456789

# WhatsApp bridge foundation: use WhatsApp Cloud API or Twilio only.
WHATSAPP_PROVIDER=cloud_api
WHATSAPP_ACCESS_TOKEN=YOUR_WHATSAPP_ACCESS_TOKEN_HERE
WHATSAPP_PHONE_NUMBER_ID=YOUR_WHATSAPP_PHONE_NUMBER_ID_HERE
WHATSAPP_VERIFY_TOKEN=YOUR_WEBHOOK_VERIFY_TOKEN_HERE
WHATSAPP_ALLOWED_NUMBERS=+16474842752,+14377727501,4377702197
WHATSAPP_TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID_HERE
WHATSAPP_TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN_HERE
WHATSAPP_TWILIO_FROM=YOUR_TWILIO_PHONE_NUMBER_HERE

# YouTube connector foundation (OAuth)
YOUTUBE_CLIENT_ID=YOUR_YOUTUBE_CLIENT_ID_HERE
YOUTUBE_CLIENT_SECRET=YOUR_YOUTUBE_CLIENT_SECRET_HERE
YOUTUBE_REFRESH_TOKEN=YOUR_YOUTUBE_REFRESH_TOKEN_HERE
YOUTUBE_CHANNEL_ID=YOUR_YOUTUBE_CHANNEL_ID_HERE

# Meta social publish foundation (backend-only; keep real values in .env)
META_ACCESS_TOKEN=YOUR_META_ACCESS_TOKEN_HERE
META_APP_ID=YOUR_META_APP_ID_HERE
META_APP_SECRET=YOUR_META_APP_SECRET_HERE
META_PAGE_ID=YOUR_META_PAGE_ID_HERE
INSTAGRAM_BUSINESS_ACCOUNT_ID=YOUR_INSTAGRAM_BUSINESS_ACCOUNT_ID_HERE
META_GRAPH_API_VERSION=v20.0

# External app connectors foundation (transport not wired yet)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
OPENAI_CONNECTOR_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE
CLAUDE_CONNECTOR_MODEL=claude-3-5-sonnet-latest
NOTION_API_KEY=YOUR_NOTION_API_KEY_HERE
NOTION_PARENT_PAGE_ID=YOUR_NOTION_PARENT_PAGE_ID_HERE
CLICKUP_API_KEY=pk_204268313_TZ8XYCIH81B1QN6ZSXVO7KP1V1MFRXYJ
CLICKUP_LIST_ID=YOUR_CLICKUP_LIST_ID_HERE

# Local low-cost media generators for Miya
LOCAL_SDWEBUI_ENDPOINT=http://127.0.0.1:7860
# Optional basic auth format: username:password
LOCAL_SDWEBUI_BASIC_AUTH=
COMFYUI_ENDPOINT=http://127.0.0.1:8188

# Runway cloud video generation for Miya (backend-only secret)
RUNWAYML_API_SECRET=key_78be05cb35d0169ee24e4eb98d85d6d1ece2169ba58c8fbcbd3223b38f7bee6b723e285520fe40ffd63f58c1bddc6c0d2e384eb4d80ee76426ec5aa56d7adba6
RUNWAYML_API_BASE_URL=https://api.dev.runwayml.com
RUNWAYML_API_VERSION=2024-11-06

# Future secure mobile bridge
MOBILE_BRIDGE_ENABLED=false

# Updater release pipeline (shell environment preferred for signing keys)
ALPHONSO_UPDATE_BASE_URL=https://releases.example.com/alphonso/windows
